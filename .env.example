# =============================================================================
# Roost Configuration
# =============================================================================

# -- Core --
SESSION_SECRET=change-me-to-a-random-string
WEB_USERNAME=admin
WEB_PASSWORD=change-me
HOST=0.0.0.0
PORT=8080

# -- Feature Flags --
GOOGLE_ENABLED=false
GMAIL_ENABLED=false
MS_ENABLED=false
AI_ENABLED=false
TELEGRAM_ENABLED=false
NOTION_ENABLED=false
INFRA_ENABLED=true
SSH_ENABLED=true

# -- Google OAuth (if GOOGLE_ENABLED=true) --
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GMAIL_SEND_FROM=your-email@gmail.com

# -- Microsoft Graph (if MS_ENABLED=true) --
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=

# -- Gemini AI (if AI_ENABLED=true) --
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# -- Telegram Bot (if TELEGRAM_ENABLED=true) --
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=

# -- Notion (if NOTION_ENABLED=true) --
NOTION_API_TOKEN=

# -- Access Control --
ALLOWED_EMAILS=
ALLOWED_DOMAINS=example.com
AUTO_PROVISION=true
MULTI_TENANT=false

# -- SSH Access --
SSH_PASSWORD=change-me

# -- Anthropic (for Claude Code inside container) --
ANTHROPIC_API_KEY=
